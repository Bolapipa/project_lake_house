name: CI/CD open_meteo

on:
  push:
    branches:
      - dev
      - prod
    paths:
      - 'open_meteo/**'
      - '.github/workflows/open_meteo-ci-cd.yml'

  pull_request:
    branches:
      - dev
      - prod
    paths:
      - 'open_meteo/**'
      - '.github/workflows/open_meteo-ci-cd.yml'

  workflow_dispatch:

jobs:
  validate-open-meteo:
    name: Validar bundle open_meteo
    runs-on: ubuntu-latest

    env:
      DATABRICKS_HOST: ${{ secrets.DATABRICKS_HOST }}
      DATABRICKS_TOKEN: ${{ secrets.DATABRICKS_TOKEN }}

    defaults:
      run:
        working-directory: open_meteo

    steps:
      - name: Checkout código
        uses: actions/checkout@v4

      - name: Instalar Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Instalar Databricks CLI
        uses: databricks/setup-cli@v0.278.0

      - name: Instalar uv
        run: python -m pip install uv

      - name: Validar autenticação Databricks
        run: databricks current-user me

      - name: Validar bundle open_meteo DEV
        if: github.ref == 'refs/heads/dev'
        run: databricks bundle validate -t dev

      - name: Validar bundle open_meteo PROD
        if: github.ref == 'refs/heads/prod'
        run: databricks bundle validate -t prod

  deploy-open-meteo-dev:
    name: Deploy open_meteo DEV
    runs-on: ubuntu-latest
    needs: validate-open-meteo
    if: github.ref == 'refs/heads/dev' && github.event_name != 'pull_request'

    env:
      DATABRICKS_HOST: ${{ secrets.DATABRICKS_HOST }}
      DATABRICKS_TOKEN: ${{ secrets.DATABRICKS_TOKEN }}

    defaults:
      run:
        working-directory: open_meteo

    steps:
      - name: Checkout código
        uses: actions/checkout@v4

      - name: Instalar Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Instalar Databricks CLI
        uses: databricks/setup-cli@v0.278.0

      - name: Instalar uv
        run: python -m pip install uv

      - name: Deploy bundle open_meteo em DEV
        run: databricks bundle deploy -t dev --auto-approve

  deploy-open-meteo-prod:
    name: Deploy open_meteo PROD
    runs-on: ubuntu-latest
    needs: validate-open-meteo
    if: github.ref == 'refs/heads/prod' && github.event_name != 'pull_request'

    env:
      DATABRICKS_HOST: ${{ secrets.DATABRICKS_HOST }}
      DATABRICKS_TOKEN: ${{ secrets.DATABRICKS_TOKEN }}

    defaults:
      run:
        working-directory: open_meteo

    steps:
      - name: Checkout código
        uses: actions/checkout@v4

      - name: Instalar Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Instalar Databricks CLI
        uses: databricks/setup-cli@v0.278.0

      - name: Instalar uv
        run: python -m pip install uv

      - name: Deploy bundle open_meteo em PROD
        run: databricks bundle deploy -t prod --auto-approve
